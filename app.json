{
  "expo": {
    "name": "Vocal Health",
    "slug": "vocal-health",
    "scheme": "vocalhealth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
   
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.avinash.vocalhealth"
    },
    "android": {
      "package": "com.avinash.vocalhealth",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-foreground.png",
        "backgroundColor": "#020617"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
